<?xml version="1.0" encoding="utf-8"?>
<odoo>
    <!-- Root Menu -->
    <menuitem id="menu_cash_shift_root" name="Cash Shifts" sequence="30" web_icon="cash_shift_handover,static/description/icon.png"/>

    <!-- Actions -->
    <record id="action_cash_shift_handover" model="ir.actions.act_window">
        <field name="name">Handovers</field>
        <field name="res_model">cash.shift.handover</field>
        <field name="view_mode">tree,form</field>
        <field name="context">{'search_default_my_handovers': 1}</field>
        <field name="help" type="html">
          <p class="o_view_nocontent_smiling_face">
            Create your first cash shift handover
          </p><p>
            Track cash safe transfers between users with full accountability.
          </p>
        </field>
    </record>

    <!-- Menus -->
    <menuitem id="menu_cash_shift_handovers" 
              name="Handovers" 
              parent="menu_cash_shift_root"
              action="action_cash_shift_handover"
              sequence="10"/>
</odoo>