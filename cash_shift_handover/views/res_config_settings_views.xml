<?xml version="1.0" encoding="utf-8"?>
<odoo>
    <record id="res_config_settings_view_form_inherit_cash_shift" model="ir.ui.view">
        <field name="name">res.config.settings.view.form.inherit.cash.shift</field>
        <field name="model">res.config.settings</field>
        <field name="inherit_id" ref="account.res_config_settings_view_form"/>
        <field name="arch" type="xml">
            <app name="account" position="inside">
                <h2>Cash Shift Management</h2>
                <div class="row mt16 o_settings_container">
                    <div class="col-12 col-lg-6 o_setting_box">
                        <div class="o_setting_right_pane">
                            <label for="cash_shift_suspense_account_id" string="Suspense Account"/>
                            <div class="text-muted">Account for handover differences.</div>
                            <div class="content-group"><div class="mt16"><field name="cash_shift_suspense_account_id"/></div></div>
                        </div>
                    </div>
                </div>
            </app>
        </field>
    </record>
</odoo>